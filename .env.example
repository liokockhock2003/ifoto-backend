# Copy this file to .env and fill in your values
# .env is in .gitignore — never commit real credentials

# Development database
DEV_DB_URL=jdbc:mysql://localhost:3306/ifotodb?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Kuala_Lumpur
DEV_DB_USER=
DEV_DB_PASS=

# Test / Staging database
TEST_DB_URL=jdbc:mysql://localhost:3306/ifotodb_test?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Kuala_Lumpur
TEST_DB_USER=
TEST_DB_PASS=

# Production database (Railway, PlanetScale, etc.)
PROD_DB_URL=jdbc:mysql://<host>:3306/ifotodb_prod?useSSL=true&serverTimezone=Asia/Kuala_Lumpur
PROD_DB_USER=
PROD_DB_PASS=